{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dispatch",
  "version": "0.2.8",
  "identifier": "com.dispatch.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Dispatch",
        "width": 960,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 20, "y": 18 }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://*.slack-edge.com https://avatars.slack-edge.com https://secure.gravatar.com data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://slack.com https://api.anthropic.com"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zmh/dispatch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFRThGODE4MEU3RkU1MApSV1JRL3VlQWdZL3VCZHpnRDMyUCtIakZqNnBrbWRtSjFKYUZMQlRNajBPbGhsZkZTWWxJUWZSQQo="
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
